{
  "name": "astral-code",
  "version": "0.1.4",
  "description": "Analyse any codebase with Claude — at scale, at 50% cost",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/azharuddinkhan3005/astral"
  },
  "homepage": "https://github.com/azharuddinkhan3005/astral",
  "keywords": ["claude", "anthropic", "batch-api", "code-analysis", "tree-sitter", "ai"],
  "engines": {
    "node": ">= 18"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "*.node",
    "src/ts/**/*.ts"
  ],
  "scripts": {
    "build": "napi build --release",
    "build:debug": "napi build",
    "test": "node -e \"const { Analyser } = require('./index.js'); const a = new Analyser('{}'); console.log('OK:', a.scan(process.cwd()).length, 'chunks')\"",
    "prepublishOnly": "echo 'ready to publish'"
  },
  "napi": {
    "name": "astral-code",
    "triples": {
      "defaults": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
